Prefix(:=<urn:unnamed:ontology#ont5>)
Prefix(owl:=<http://www.w3.org/2002/07/owl#>)
Prefix(rdf:=<http://www.w3.org/1999/02/22-rdf-syntax-ns#>)
Prefix(xml:=<http://www.w3.org/XML/1998/namespace>)
Prefix(xsd:=<http://www.w3.org/2001/XMLSchema#>)
Prefix(rdfs:=<http://www.w3.org/2000/01/rdf-schema#>)


Ontology(<urn:unnamed:ontology#ont5>

Declaration(Class(<urn:dosdp:defined_class>))
Declaration(Class(<urn:dosdp:structure>))
Declaration(ObjectProperty(<http://purl.obolibrary.org/obo/BFO_0000050>))
Declaration(AnnotationProperty(<http://www.geneontology.org/formats/oboInOwl#hasDbXref>))
Declaration(AnnotationProperty(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym>))



############################
#   Classes
############################

# Class: <urn:dosdp:defined_class> (part of urn:dosdp:structure)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "$xref_list") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <urn:dosdp:defined_class> "$synonym")
AnnotationAssertion(rdfs:label <urn:dosdp:defined_class> "part of urn:dosdp:structure")
AnnotationAssertion(rdfs:seeAlso <urn:dosdp:defined_class> "$synonym")
SubClassOf(<urn:dosdp:defined_class> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <urn:dosdp:structure>))


)