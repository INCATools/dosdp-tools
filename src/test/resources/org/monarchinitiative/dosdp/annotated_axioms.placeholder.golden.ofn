Prefix(:=<urn:unnamed:ontology#ont5>)
Prefix(owl:=<http://www.w3.org/2002/07/owl#>)
Prefix(rdf:=<http://www.w3.org/1999/02/22-rdf-syntax-ns#>)
Prefix(xml:=<http://www.w3.org/XML/1998/namespace>)
Prefix(xsd:=<http://www.w3.org/2001/XMLSchema#>)
Prefix(rdfs:=<http://www.w3.org/2000/01/rdf-schema#>)


Ontology(<urn:unnamed:ontology#ont5>

Declaration(Class(<urn:dosdp:defined_class>))
Declaration(Class(<urn:dosdp:structure>))
Declaration(ObjectProperty(<http://purl.obolibrary.org/obo/BFO_0000050>))
Declaration(AnnotationProperty(<http://purl.obolibrary.org/obo/IAO_0000115>))
Declaration(AnnotationProperty(<http://purl.org/dc/terms/contributor>))
Declaration(AnnotationProperty(<http://www.geneontology.org/formats/oboInOwl#source>))



############################
#   Classes
############################

# Class: <urn:dosdp:defined_class> (part of urn:dosdp:structure)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <urn:dosdp:defined_class> "Anything part of urn:dosdp:structure.")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#source> "sub-annotation $note") <http://purl.org/dc/terms/contributor> <urn:dosdp:defined_class> "$note")
AnnotationAssertion(rdfs:label <urn:dosdp:defined_class> "part of urn:dosdp:structure")
SubClassOf(Annotation(<http://www.geneontology.org/formats/oboInOwl#source> "$note") <urn:dosdp:defined_class> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <urn:dosdp:structure>))


)