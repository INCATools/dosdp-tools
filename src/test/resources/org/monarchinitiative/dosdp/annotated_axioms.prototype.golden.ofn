Prefix(:=<urn:unnamed:ontology#ont1>)
Prefix(owl:=<http://www.w3.org/2002/07/owl#>)
Prefix(rdf:=<http://www.w3.org/1999/02/22-rdf-syntax-ns#>)
Prefix(xml:=<http://www.w3.org/XML/1998/namespace>)
Prefix(xsd:=<http://www.w3.org/2001/XMLSchema#>)
Prefix(rdfs:=<http://www.w3.org/2000/01/rdf-schema#>)


Ontology(<urn:unnamed:ontology#ont1>

Declaration(Class(<http://purl.obolibrary.org/obo/test/annotated_axioms.yaml>))
Declaration(ObjectProperty(<http://purl.obolibrary.org/obo/BFO_0000050>))
Declaration(AnnotationProperty(<http://purl.obolibrary.org/obo/IAO_0000115>))
Declaration(AnnotationProperty(<http://purl.org/dc/terms/contributor>))
Declaration(AnnotationProperty(<http://purl.org/dc/terms/title>))
Declaration(AnnotationProperty(<http://www.geneontology.org/formats/oboInOwl#source>))



############################
#   Classes
############################

# Class: <http://purl.obolibrary.org/obo/test/annotated_axioms.yaml> (part of 'thing')

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/test/annotated_axioms.yaml> "Anything part of 'thing'.")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#source> "sub-annotation xsd:string") <http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/test/annotated_axioms.yaml> "xsd:string")
AnnotationAssertion(<http://purl.org/dc/terms/title> <http://purl.obolibrary.org/obo/test/annotated_axioms.yaml> "annotated_axioms")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/test/annotated_axioms.yaml> "part of 'thing'")
SubClassOf(Annotation(<http://www.geneontology.org/formats/oboInOwl#source> "xsd:string") <http://purl.obolibrary.org/obo/test/annotated_axioms.yaml> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> owl:Thing))


)